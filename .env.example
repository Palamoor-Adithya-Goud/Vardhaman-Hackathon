# ==========================================
# Chroma DB Configuration
# ==========================================

# Choose 'local' for an in-memory/persistent SQLite instance or 'remote' for self-hosted/Chroma Cloud
CHROMA_MODE=local

# ----------------------------
# 1. Local Persistence Settings (Used if CHROMA_MODE=local)
# ----------------------------
# Folder path where local database and vectors are stored
CHROMA_PERSIST_DIRECTORY=./chromadb_data

# ----------------------------
# 2. Remote / Hosted Client Settings (Used if CHROMA_MODE=remote)
# ----------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
# Optional authentication token/API key if your Chroma DB instance is secured
CHROMA_API_KEY=your-chroma-api-key-here
# Optional tenant and database names (defaults are 'default_tenant' and 'default_database')
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# ----------------------------
# 3. Collection & PDF Settings
# ----------------------------
CHROMA_COLLECTION_NAME=pdf_documents
PDF_PATH=path/to/your/document.pdf

# ----------------------------
# 4. Groq LLM Settings
# ----------------------------
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------
# 5. Tavily Search Settings
# ----------------------------
TAVILY_API_KEY=your-tavily-api-key-here

# ----------------------------
# 6. Relational Database Settings
# ----------------------------
DATABASE_URL=sqlite:///./faculty_rag.db

# ----------------------------
# 7. RAG Tuning
# ----------------------------
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=1.2

